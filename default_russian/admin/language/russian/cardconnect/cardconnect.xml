  <definition>
    <key>cardconnect_status_decline</key>
    <value><![CDATA[Отклонено:<br /><span class="help">Статус заказа, который вы хотите зафиксировать в истории в ответ на статус платежного процессора. Основной статус заказа не затрагивается. Заказ не будет размещен, только после успешного платежа.</span>]]></value>
  </definition>
  <definition>
